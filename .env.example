# ============================================================================
# PredictStack - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# Never commit your .env file to version control!
# ============================================================================

# Network: testnet or mainnet
NETWORK=testnet
PORT=4000
CONTRACT_ADDRESS=ST30VGN68PSGVWGNMD0HH2WQMM5T486EK3WBNTHCY
CONTRACT_NAME=predictionmarketv7
BACKEND_DATA_FILE=backend/data/store.json
PLATFORM_FEE_MICRO=10000

# ============================================================================
# Stacks Configuration
# ============================================================================

# Your Stacks wallet private key (hex string, no prefix)
# Used for contract deployment and admin/oracle operations
STACKS_PRIVATE_KEY=YOUR_STACKS_PRIVATE_KEY_HERE

# ============================================================================
# Getting Started
# ============================================================================
#
# 1. Get testnet STX:
#    - https://explorer.hiro.so/sandbox/faucet?chain=testnet
#
# 2. Deploy to testnet:
#    npm run deploy:testnet
#
# ============================================================================
