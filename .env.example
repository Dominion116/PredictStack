# ============================================================================
# PredictStack - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# Never commit your .env file to version control!
# ============================================================================

# Network: mainnet | testnet
# Mainnet deployer: SP30VGN68PSGVWGNMD0HH2WQMM5T486EK3YGP7Z3Y
# Testnet deployer: ST30VGN68PSGVWGNMD0HH2WQMM5T486EK3WBNTHCY
NETWORK=mainnet
PORT=4000
CONTRACT_ADDRESS=SP30VGN68PSGVWGNMD0HH2WQMM5T486EK3YGP7Z3Y
CONTRACT_NAME=predictionmarketv7
PLATFORM_FEE_MICRO=10000

# MongoDB Atlas connection string
# Create a free cluster at https://cloud.mongodb.com
# Use database name: predictstack
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/predictstack?retryWrites=true&w=majority

# ============================================================================
# Stacks Configuration
# ============================================================================

# Your Stacks wallet private key (hex string, no prefix)
# Used for contract deployment and admin/oracle operations
STACKS_PRIVATE_KEY=YOUR_STACKS_PRIVATE_KEY_HERE

# ============================================================================
# Pinata IPFS (server-side only — do NOT use NEXT_PUBLIC_ prefix)
# ============================================================================
# Get keys at https://app.pinata.cloud/ → API Keys
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here

# ============================================================================
# Getting Started
# ============================================================================
#
# 1. Get testnet STX:
#    - https://explorer.hiro.so/sandbox/faucet?chain=testnet
#
# 2. Deploy to testnet:
#    npm run deploy:testnet
#
# ============================================================================
