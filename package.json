{
  "name": "predictstack",
  "version": "1.0.0",
  "description": "A peer-to-peer prediction market platform on Stacks blockchain using STX",
  "private": false,
  "scripts": {
    "test": "vitest run",
    "test:report": "vitest run -- --coverage --costs",
    "test:watch": "chokidar \"tests/**/*.ts\" \"contracts/**/*.clar\" -c \"npm run test:report\"",
    "deploy:testnet": "clarinet deployment generate --testnet && clarinet deployment apply --testnet",
    "deploy:mainnet": "clarinet deployment generate --mainnet && clarinet deployment apply --mainnet",
    "check": "clarinet check",
    "console": "clarinet console"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@hirosystems/clarinet-sdk": "^3.8.1",
    "@sinclair/typebox": "^0.32.35",
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.0.5",
    "axios": "^1.13.2",
    "chokidar-cli": "^3.0.0",
    "dotenv": "^16.6.1",
    "typescript": "^5.6.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.0",
    "vitest-environment-clarinet": "^2.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@stacks/wallet-sdk": "^7.2.0",
    "ts-node": "^10.9.2"
  }
}
