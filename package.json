{
  "name": "predictstack",
  "version": "1.0.0",
  "description": "A peer-to-peer prediction market platform on Stacks blockchain using STX",
  "type": "module",
  "private": false,
  "scripts": {
    "backend": "node backend/server.mjs",
    "frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:report": "vitest run -- --coverage --costs",
    "test:watch": "chokidar \"tests/**/*.ts\" \"contracts/**/*.clar\" -c \"npm run test:report\"",
    "deploy:testnet": "clarinet deployments generate --testnet --medium-cost && clarinet deployments apply --testnet --use-on-disk-deployment-plan --no-dashboard",
    "deploy:mainnet": "clarinet deployments generate --mainnet --medium-cost && clarinet deployments apply --mainnet --use-on-disk-deployment-plan --no-dashboard",
    "deploy-and-init": "node scripts/deploy-and-init.mjs",
    "init-contract": "node scripts/deploy-and-init.mjs --init",
    "check": "clarinet check",
    "console": "clarinet console",
    "validate:env": "node scripts/validate-env.mjs",
    "audit:gitignore": "node scripts/audit-gitignore.mjs",
    "list:markets": "node scripts/list-markets.mjs"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@hirosystems/clarinet-sdk": "^3.8.1",
    "@sinclair/typebox": "^0.32.35",
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.5.0",
    "axios": "^1.13.2",
    "chokidar-cli": "^3.0.0",
    "clarityxo-ai": "^0.1.0",
    "dotenv": "^16.6.1",
    "mongodb": "^7.2.0",
    "predictstackjssdk": "^0.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.6.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.0",
    "vitest-environment-clarinet": "^2.3.0"
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "@stacks/wallet-sdk": "^7.2.0",
    "ts-node": "^10.9.2"
  }
}
