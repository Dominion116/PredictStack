# ===========================================
# PredictStack Frontend Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control!

# Network Configuration
# Options: 'testnet', 'mainnet', 'devnet'
NEXT_PUBLIC_NETWORK=testnet
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_CONTRACT_ADDRESS=ST30VGN68PSGVWGNMD0HH2WQMM5T486EK3WBNTHCY
NEXT_PUBLIC_CONTRACT_NAME=predictionmarketv7

# NOTE: Pinata/IPFS keys belong in the ROOT .env (backend only).
# They must NOT use the NEXT_PUBLIC_ prefix or they will be exposed
# in the client-side JavaScript bundle.
# See root .env.example for PINATA_API_KEY and PINATA_SECRET_KEY.

# ===========================================
# Optional: Analytics & Monitoring
# ===========================================
# NEXT_PUBLIC_ANALYTICS_ID=
