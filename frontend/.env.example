# ===========================================
# PredictStack Frontend Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or .env.production to version control!
#
# Validate your setup: node scripts/validate-env.mjs

# ── Network ──────────────────────────────────────────────────────
# Options: 'testnet' | 'mainnet' | 'devnet'
# Mainnet deployer: SP30VGN68PSGVWGNMD0HH2WQMM5T486EK3YGP7Z3Y
# Testnet deployer: ST30VGN68PSGVWGNMD0HH2WQMM5T486EK3WBNTHCY
NEXT_PUBLIC_NETWORK=mainnet

# ── Backend ───────────────────────────────────────────────────────
# Local dev:    http://localhost:4000
# Render prod:  https://predictstack.onrender.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# ── Contract ──────────────────────────────────────────────────────
NEXT_PUBLIC_CONTRACT_ADDRESS=SP30VGN68PSGVWGNMD0HH2WQMM5T486EK3YGP7Z3Y
NEXT_PUBLIC_CONTRACT_NAME=predictstacksv2

# ── Security note ─────────────────────────────────────────────────
# Pinata/IPFS and Stacks private keys belong in the ROOT .env (backend only).
# NEVER use NEXT_PUBLIC_ prefix for secrets — they will be exposed in the browser.
# See root .env.example for PINATA_API_KEY, PINATA_SECRET_KEY, STACKS_PRIVATE_KEY.

# ── Optional: Analytics & Monitoring ─────────────────────────────
# NEXT_PUBLIC_ANALYTICS_ID=
